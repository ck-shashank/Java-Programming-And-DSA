package pkg1;

public class REcursion {
public static void main(String[] args) {
	int num =7;
	int i =1;
	int sum =0;
	perfect(i,num,sum);
	
}
public static void perfect(int i, int num, int sum)
{
	if(i==num) {
		if(sum==num) {
			System.out.println("Perfect number");
			return ;
		}
		else {
			System.out.println("Not perfect number");
			
		}
	}
	
	if(num%i==0)
		sum=sum+i;
	perfect(++i, num , sum);
		
}
}
