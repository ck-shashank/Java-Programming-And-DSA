package pkg1;

public class primeRecursion {
public static void main(String[] args) {
	int num=2;
	int i=1;
	int count=0;
	print(i,num,count);
}
public static void print(int i, int num, int count)
{
	if(i>num)
	{
		if(count==2)
		{
			System.out.println("Prime number");
			return;
		}
		else
		{
			System.out.println("Not Prime number");
			return;
		}
	}
	if(num%i==0)
	{
		count++;
	}
	print(++i, num, count);
}
}
