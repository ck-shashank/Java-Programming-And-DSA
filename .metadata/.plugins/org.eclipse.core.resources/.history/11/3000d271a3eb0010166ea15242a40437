package library;

import java.util.Scanner;

public class InputValidator {

    public static int readInt(Scanner sc, String message) {
        int num;
        while (true) {
            System.out.print(message);
            String input = sc.nextLine().trim();
            try {
                num = Integer.parseInt(input);
                if (num <= 0) throw new NumberFormatException();
                return num;
            } catch (NumberFormatException e) {
                System.out.println("❌ Invalid number. Enter positive digits only.");
            }
        }
    }

    public static String readName(Scanner sc, String message) {
        while (true) {
            System.out.print(message);
            String input = sc.nextLine().trim();
            if (input.matches("[A-Za-z ]+") && !input.isEmpty()) return input;
            else System.out.println("❌ Invalid input. Only letters and spaces allowed.");
        }
    }

    public static String readUsername(Scanner sc) {
        while (true) {
            System.out.print("Username: ");
            String input = sc.nextLine().trim();
            if (input.matches(".*[A-Za-z].*") && input.length() >= 3) return input;
            else System.out.println("❌ Username must be at least 3 chars with letters.");
        }
    }

    public static String readUsername(Scanner sc, String message) {
        while (true) {
            System.out.print(message);
            String input = sc.nextLine().trim();
            if (input.matches(".*[A-Za-z].*") && input.length() >= 3) return input;
            else System.out.println("❌ Username must be at least 3 chars with letters.");
        }
    }

    public static String readPassword(Scanner sc, String message) {
        while (true) {
            System.out.print(message);
            String input = sc.nextLine().trim();
            if (input.length() >= 4) return input;
            else System.out.println("❌ Password must be at least 4 characters.");
        }
    }

    public static String readPhone(Scanner sc) {
        while (true) {
            System.out.print("Phone (10 digits): ");
            String input = sc.nextLine().trim();
            if (input.matches("\\d{10}")) return input;
            else System.out.println("❌ Invalid phone number.");
        }
    }
    public static String readString(Scanner sc, String message) {
        while (true) {
            System.out.print(message);
            String input = sc.nextLine().trim();
            if (!input.isEmpty()) return input;
            else System.out.println("❌ Input cannot be empty.");
        }
    }

}
