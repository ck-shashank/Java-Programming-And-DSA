package library;

import java.util.*;
import java.time.LocalDate;
import java.time.temporal.ChronoUnit;
import java.time.format.DateTimeFormatter;

public class Library {

    public Map<Integer, Book> books = new HashMap<>();
    public Map<String, User> users = new HashMap<>();
    public Map<String, Admin> admins = new HashMap<>();

    public Admin loggedInAdmin = null;
    public User loggedInUser = null;

    private static final int MAX_ISSUE = 3;
    private static final int DUE_DAYS = 14;
    private static final int FINE_PER_DAY = 5;

    // ================= ADMIN =================
    public void registerAdmin(Admin a) {
        if (admins.containsKey(a.username)) {
            System.out.println("❌ Admin username already exists.");
            return;
        }
        admins.put(a.username, a);
        System.out.println("✅ Admin registered successfully.");
    }

    public boolean adminLogin(String username, String password) {
        Admin a = admins.get(username);
        if (a != null && a.password.equals(password)) {
            loggedInAdmin = a;
            return true;
        }
        return false;
    }

    public void adminLogout() {
        loggedInAdmin = null;
    }

    // ================= USER =================
    public void registerUser(User u) {
        if (users.containsKey(u.username)) {
            System.out.println("❌ Username already exists.");
            return;
        }
        users.put(u.username, u);
        System.out.println("✅ User registered successfully.");
    }

    public boolean userLogin(String username, String password) {
        User u = users.get(username);
        if (u != null && u.password.equals(password)) {
            loggedInUser = u;
            return true;
        }
        return false;
    }

    public void userLogout() {
        loggedInUser = null;
    }

    // ================= BOOK =================
    public void addBook(Book b) {
        if (loggedInAdmin == null) {
            System.out.println("❌ Admin login required.");
            return;
        }
        if (books.containsKey(b.id)) {
            books.get(b.id).addCopy(b.copies);
            System.out.println("✅ Copies updated. Total: " + books.get(b.id).copies);
        } else {
            books.put(b.id, b);
            System.out.println("✅ Book added successfully.");
        }
    }

    public void updateBook(int id, String title, String author) {
        if (loggedInAdmin == null) return;
        Book b = books.get(id);
        if (b == null) {
            System.out.println("❌ Book not found.");
            return;
        }
        b.title = title;
        b.author = author;
        System.out.println("✅ Book updated.");
    }

    public void deleteBook(int id) {
        if (loggedInAdmin == null) return;
        if (books.remove(id) != null)
            System.out.println("✅ Book deleted.");
        else
            System.out.println("❌ Book not found.");
    }

    public void viewBooks() {
        System.out.printf("%-5s | %-25s | %-20s\n", "ID", "Title", "Author");
        System.out.println("-------------------------------------------------------------");
        for (Book b : books.values()) {
            if (b.isAvailable()) {
                System.out.printf("%-5d | %-25s | %-20s\n", b.id, b.title, b.author);
            }
        }
    }

    // ================= ISSUE =================
    public void adminIssueBook(int bookId, String username) {
        if (loggedInAdmin == null) {
            System.out.println("❌ Admin login required.");
            return;
        }

        Book b = books.get(bookId);
        User u = users.get(username);

        if (b == null || u == null) {
            System.out.println("❌ Book or user not found.");
            return;
        }
        if (!b.isAvailable()) {
            System.out.println("❌ Book unavailable.");
            return;
        }
        if (u.issuedBooks.size() >= MAX_ISSUE) {
            System.out.println("❌ User already has 3 books.");
            return;
        }

        b.reduceCopy();
        u.issuedBooks.add(b);

        u.history.add(new HistoryRecord(
                b.id,
                b.title,
                "Issued",
                loggedInAdmin.name,
                LocalDate.now(),
                0
        ));

        System.out.println("✅ Book '" + b.title + "' issued to " + u.username +
                " by Admin " + loggedInAdmin.name);
    }

    // ================= RETURN =================
    public void adminReturnBook(int bookId, String username) {
        if (loggedInAdmin == null) {
            System.out.println("❌ Admin login required.");
            return;
        }

        Book b = books.get(bookId);
        User u = users.get(username);

        if (b == null || u == null || !u.issuedBooks.contains(b)) {
            System.out.println("❌ Invalid return operation.");
            return;
        }

        HistoryRecord issued = null;
        for (HistoryRecord h : u.history) {
            if (h.bookId == bookId && h.action.equals("Issued")) {
                issued = h;
                break;
            }
        }

        int fine = 0;
        if (issued != null) {
            long days = ChronoUnit.DAYS.between(issued.date.plusDays(DUE_DAYS), LocalDate.now());
            if (days > 0) fine = (int) days * FINE_PER_DAY;
        }

        b.increaseCopy();
        u.issuedBooks.remove(b);

        u.history.add(new HistoryRecord(
                b.id,
                b.title,
                "Returned",
                loggedInAdmin.name,
                LocalDate.now(),
                fine
        ));

        System.out.println("✅ Book returned. Fine: ₹" + fine);
    }

    // ================= HISTORY =================
    public void viewUserHistory(String username) {
        User u = users.get(username);
        if (u == null) return;

        System.out.printf("%-5s | %-25s | %-10s | %-15s | %-12s | %-6s\n",
                "ID", "Title", "Action", "Admin", "Date", "Fine");
        System.out.println("----------------------------------------------------------------------------");

        for (HistoryRecord h : u.history) {
            System.out.printf("%-5d | %-25s | %-10s | %-15s | %-12s | %-6d\n",
                    h.bookId, h.title, h.action, h.adminName,
                    h.date.format(DateTimeFormatter.ofPattern("yyyy-MM-dd")),
                    h.fine);
        }
    }

    // ================= REPORTS =================
    public void reportOverdueBooks() {
        System.out.println("📄 OVERDUE BOOK REPORT");
        LocalDate today = LocalDate.now();

        for (User u : users.values()) {
            for (HistoryRecord h : u.history) {
                if (h.action.equals("Issued") &&
                        h.date.plusDays(DUE_DAYS).isBefore(today)) {

                    long days = ChronoUnit.DAYS.between(h.date.plusDays(DUE_DAYS), today);
                    int fine = (int) days * FINE_PER_DAY;

                    System.out.println(
                            h.title + " | User: " + u.username +
                            " | Overdue Days: " + days +
                            " | Fine: ₹" + fine
                    );
                }
            }
        }
    }
}
