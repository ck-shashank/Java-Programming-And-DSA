package String;

public class UpperLower {
 public static void main(String[] args) {
	 String str="Java";
	 String str1="Programing In Java";
	 System.out.println(str);
	 System.out.println(toUpperCase(str));
	 System.out.println(str1);
	 System.out.println(toLpperCase(str1));
	 System.out.println(str);
	 str=str.toUpperCase();
	 System.out.println(str);
	 str=str.toLowerCase();
 }
 public static String toUpperCase(String str) {
	 String result="";
	 for(int i=0;i<str.length();i++) {
		 char ch=str.charAt(i);
		 if(ch>='a' && ch<='z') {
			 ch-=32;
			 result+=ch;
		 }
		 else
			 result+=ch;
	 }
	 return result;
 }

public static String toLpperCase(String str) {
	 String result="";
	 for(int i=0;i<str.length();i++) {
		 char ch=str.charAt(i);
		 if(ch>='A' && ch<='Z') {
			 ch+=32;
			 result+=ch;
		 }
		 else
			 result+=ch;
	 }
	 return result;
}
}
