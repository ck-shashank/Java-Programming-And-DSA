package library;

import java.util.*;
import java.time.LocalDate;
import java.time.format.DateTimeFormatter;
import java.time.temporal.ChronoUnit;

public class Library {

    public Map<Integer, Book> books = new HashMap<>();
    public Map<String, User> users = new HashMap<>();
    public Map<String, Admin> admins = new HashMap<>();

    public Admin loggedInAdmin = null;
    public User loggedInUser = null;

    // ---------------- ADMIN ----------------
    public void registerAdmin(Admin a) {
        if (admins.containsKey(a.username)) {
            System.out.println("❌ Admin username already exists.");
            return;
        }
        admins.put(a.username, a);
        System.out.println("✅ Admin registered successfully.");
    }

    public boolean adminLogin(String username, String password) {
        Admin a = admins.get(username);
        if (a != null && a.password.equals(password)) {
            loggedInAdmin = a;
            return true;
        }
        return false;
    }

    public void adminLogout() {
        loggedInAdmin = null;
    }

    // ---------------- USER ----------------
    public void registerUser(User u) {
        if (users.containsKey(u.username)) {
            System.out.println("❌ Username already exists.");
            return;
        }
        users.put(u.username, u);
        System.out.println("✅ User registered successfully.");
    }

    public boolean userLogin(String username, String password) {
        User u = users.get(username);
        if (u != null && u.password.equals(password)) {
            loggedInUser = u;
            return true;
        }
        return false;
    }

    public void userLogout() {
        loggedInUser = null;
    }

    // ---------------- BOOK ----------------
    public void addBook(Book b) {
        if (loggedInAdmin == null) {
            System.out.println("❌ Admin login required.");
            return;
        }
        if (books.containsKey(b.id)) {
            books.get(b.id).addCopy(b.copies);
            System.out.println("✅ Additional copies added.");
        } else {
            books.put(b.id, b);
            System.out.println("✅ Book added successfully.");
        }
    }

    public void updateBook(int id, String newTitle, String newAuthor) {
        if (loggedInAdmin == null) {
            System.out.println("❌ Admin login required.");
            return;
        }
        Book b = books.get(id);
        if (b == null) {
            System.out.println("❌ Book not found.");
            return;
        }
        b.title = newTitle;
        b.author = newAuthor;
        System.out.println("✅ Book updated successfully.");
    }

    public void deleteBook(int id) {
        if (loggedInAdmin == null) {
            System.out.println("❌ Admin login required.");
            return;
        }
        if (books.remove(id) != null)
            System.out.println("✅ Book deleted.");
        else
            System.out.println("❌ Book not found.");
    }

    public void viewBooks() {
        System.out.printf("%-5s | %-25s | %-20s\n", "ID", "Title", "Author");
        System.out.println("----------------------------------------------------------");
        for (Book b : books.values())
            if (b.isAvailable())
                System.out.printf("%-5d | %-25s | %-20s\n", b.id, b.title, b.author);
    }

    public void viewAllBooksAdmin() {
        System.out.printf("%-5s | %-25s | %-20s | %-6s\n",
                "ID", "Title", "Author", "Copies");
        System.out.println("---------------------------------------------------------------");
        for (Book b : books.values())
            System.out.printf("%-5d | %-25s | %-20s | %-6d\n",
                    b.id, b.title, b.author, b.copies);
    }

    public void searchBook(Integer id, String title, String author) {
        boolean found = false;
        for (Book b : books.values()) {
            if ((id != null && b.id == id) ||
                (title != null && b.title.equalsIgnoreCase(title)) ||
                (author != null && b.author.equalsIgnoreCase(author))) {
                System.out.println(b.id + " | " + b.title + " | " + b.author);
                found = true;
            }
        }
        if (!found)
            System.out.println("❌ Book not found.");
    }

    // ---------------- ISSUE BOOK ----------------
    public void adminIssueBook(int bookId, String username) {
        if (loggedInAdmin == null) {
            System.out.println("❌ Admin login required.");
            return;
        }

        Book b = books.get(bookId);
        User u = users.get(username);

        if (b == null || u == null) {
            System.out.println("❌ Book or User not found.");
            return;
        }

        if (!b.isAvailable()) {
            System.out.println("❌ Book not available.");
            return;
        }

        if (!u.canIssueMoreBooks()) {
            System.out.println("❌ User already has 3 books.");
            return;
        }

        b.reduceCopy();
        u.issuedBooks.add(b);
        u.history.add(new HistoryRecord(b.id, b.title, "Issued", loggedInAdmin.name, LocalDate.now()));

        System.out.println("✅ Book '" + b.title + "' issued to " + u.username);
    }

    // ---------------- RETURN BOOK (FINE SYSTEM HERE) ----------------
    public void adminReturnBook(int bookId, String username) {
        if (loggedInAdmin == null) {
            System.out.println("❌ Admin login required.");
            return;
        }

        Book b = books.get(bookId);
        User u = users.get(username);

        if (b == null || u == null) {
            System.out.println("❌ Book or User not found.");
            return;
        }

        if (!u.issuedBooks.contains(b)) {
            System.out.println("❌ Book not issued to this user.");
            return;
        }

        b.increaseCopy();
        u.issuedBooks.remove(b);

        LocalDate today = LocalDate.now();
        int fine = 0;

        for (HistoryRecord h : u.history) {
            if (h.bookId == bookId && h.action.equals("Issued")) {
                LocalDate dueDate = h.date.plusDays(14);
                if (today.isAfter(dueDate)) {
                    long daysLate = ChronoUnit.DAYS.between(dueDate, today);
                    fine = (int) daysLate * 10;
                }
                break;
            }
        }

        HistoryRecord r = new HistoryRecord(b.id, b.title, "Returned", loggedInAdmin.name, today);
        r.setFine(fine);
        u.history.add(r);

        System.out.println("✅ Book returned successfully.");
        if (fine > 0)
            System.out.println("💰 Fine to be paid: ₹" + fine);
    }

    // ---------------- USER HISTORY ----------------
    public void viewUserHistory(String username) {
        User u = users.get(username);
        if (u == null) {
            System.out.println("❌ User not found.");
            return;
        }

        System.out.printf("%-5s | %-25s | %-10s | %-12s | %-5s\n",
                "ID", "Title", "Action", "Date", "Fine");
        System.out.println("----------------------------------------------------------------");

        for (HistoryRecord h : u.history) {
            System.out.printf("%-5d | %-25s | %-10s | %-12s | %-5d\n",
                    h.bookId, h.title, h.action,
                    h.date.format(DateTimeFormatter.ofPattern("yyyy-MM-dd")),
                    h.fine);
        }
    }

    // ---------------- REPORTS ----------------
    public void reportOverdueBooks() {
        LocalDate today = LocalDate.now();
        System.out.println("📄 Overdue Books Report");

        for (User u : users.values()) {
            for (HistoryRecord h : u.history) {
                if (h.action.equals("Issued")) {
                    LocalDate dueDate = h.date.plusDays(14);
                    if (today.isAfter(dueDate)) {
                        int fine = (int) ChronoUnit.DAYS.between(dueDate, today) * 10;
                        System.out.println(
                                h.bookId + " | " + h.title +
                                " | User: " + u.username +
                                " | Fine: ₹" + fine
                        );
                    }
                }
            }
        }
    }

    // ---------------- UPDATE USER ----------------
    public void updateUser(String username) {
        if (loggedInAdmin == null) {
            System.out.println("❌ Admin login required.");
            return;
        }

        User u = users.get(username);
        if (u == null) {
            System.out.println("❌ User not found.");
            return;
        }

        Scanner sc = new Scanner(System.in);
        System.out.println("Updating user: " + u.username);

        System.out.print("New Name (blank to skip): ");
        String name = sc.nextLine().trim();
        if (!name.isEmpty() && name.matches("[A-Za-z ]+"))
            u.name = name;

        System.out.print("Phone (10 digits, blank to skip): ");
        String phone = sc.nextLine().trim();
        if (!phone.isEmpty() && phone.matches("\\d{10}"))
            u.phone = phone;

        System.out.print("New Password (blank to skip): ");
        String pass = sc.nextLine().trim();
        if (!pass.isEmpty())
            u.password = pass;

        System.out.println("✅ User updated successfully.");
    }

    public void deleteUser(String username) {
        if (loggedInAdmin == null) {
            System.out.println("❌ Admin login required.");
            return;
        }

        User u = users.get(username);
        if (u == null) {
            System.out.println("❌ User not found.");
            return;
        }

        if (!u.issuedBooks.isEmpty()) {
            System.out.println("❌ User has issued books.");
            return;
        }

        users.remove(username);
        System.out.println("✅ User deleted.");
    }
 // ---------------- VIEW ALL USERS ----------------
    public void viewAllUsers() {

        if (loggedInAdmin == null) {
            System.out.println("❌ Admin login required.");
            return;
        }

        if (users.isEmpty()) {
            System.out.println("ℹ️ No users registered.");
            return;
        }

        System.out.printf("%-4d | %-10s | %-20s | %-12s | %-5s\n",
                "Id", "Username", "Name", "Phone", "Issued");
        System.out.println("-----------------------------------------------------------");

        for (User u : users.values()) {
            System.out.printf("%-4d |%-10s | %-20s | %-12s | %-5d\n",
            		u.id,
                    u.username,
                    u.name,
                    u.phone,
                    u.issuedBooks.size());
        }
    }

}
