package library;

import java.util.ArrayList;
import java.util.List;

public class User {
    public int id;
    public String name;
    public String username;
    public String password;
    public String phone;

    // List of currently issued books
    public List<Book> issuedBooks = new ArrayList<>();

    // History of actions (issued, returned)
    public List<HistoryRecord> history = new ArrayList<>();

    public User(int id, String name, String username, String password, String phone) {
        this.id = id;
        this.name = name;
        this.username = username;
        this.password = password;
        this.phone = phone;
    }

    public String getStatus() {
        return issuedBooks.isEmpty() ? "Active" : "Has Books";
    }

    public boolean canIssueMoreBooks() {
        return issuedBooks.size() < 3;
    }
}
