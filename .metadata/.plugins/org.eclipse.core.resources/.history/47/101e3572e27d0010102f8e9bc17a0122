package pkg2;

public class Pattern2 {
	
		  public static void main(String[] args) {
			int num =5;
			
			for(int i=1; i< 2*num; i++)
			{
				char ch='A';
				for(int j=1; j< 2*num; j++)
				{
					if(i+j>num && j-i<num && i-j<num && i+j> 2*num)
					{
					System.out.print(ch++ +" ");
					}
					else {
						System.out.println("  ");
					}
				}
				System.out.println("  ");
				ch++;
			}
		}
		

}
